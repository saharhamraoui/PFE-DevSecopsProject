{
  "title": "Cloud Run - my-app",
  "uid": "cloud-run-dashboard",
  "description": "Monitoring dashboard for Cloud Run service my-app (sahar-pfe)",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "links": [],
  "tags": ["cloud-run", "gcp"],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Requests",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "stackdriver", "uid": "google-cloud-monitoring" },
      "targets": [
        {
          "refId": "A",
          "queryType": "metrics",
          "metricQuery": {
            "projectName": "sahar-pfe",
            "metricType": "run.googleapis.com/request_count",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM",
            "alignmentPeriod": "cloud-monitoring-auto",
            "groupBys": ["resource.labels.service_name"],
            "filters": [],
            "view": "FULL"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "5xx Error Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "stackdriver", "uid": "google-cloud-monitoring" },
      "targets": [
        {
          "refId": "A",
          "queryType": "metrics",
          "metricQuery": {
            "projectName": "sahar-pfe",
            "metricType": "run.googleapis.com/request_count",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM",
            "alignmentPeriod": "cloud-monitoring-auto",
            "groupBys": ["resource.labels.service_name"],
            "filters": [
              "metric.labels.response_code_class", "=", "5xx"
            ],
            "view": "FULL"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
