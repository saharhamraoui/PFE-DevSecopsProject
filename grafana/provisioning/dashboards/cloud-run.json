    {
      "id": 8,
      "type": "timeseries",
      "title": "CPU Utilization (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "stackdriver", "uid": "google-cloud-monitoring" },
      "targets": [
        {
          "refId": "A",
          "queryType": "metrics",
          "metricQuery": {
